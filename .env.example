# CivicGuard AI Environment Variables Example

# Gemini API Key (Required for real ADK Agent Pipeline)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key (For secure token signing)
# Replace with a long random secret string in production
JWT_SECRET=civicguard-secure-secret-key-98765

# Port for Flask application (Default is 5000)
PORT=5000
